# Configuración del servidor backend
# Copia este fichero como .env y ajusta los valores

PORT=4000

# URL del servidor Apache Jena Fuseki
FUSEKI_URL=http://localhost:3030

# Nombre del dataset configurado en Fuseki
FUSEKI_DATASET=recursos

# Credenciales de acceso a Fuseki
FUSEKI_USER=admin
FUSEKI_PASSWORD=

# Clave secreta para firmar los JWT (usa una cadena larga y aleatoria en producción)
JWT_SECRET=

# Tiempo de expiración del token JWT
JWT_EXPIRES_IN=24h
