# Plantilla de variables de entorno.
# Copia este fichero a .env y rellena los valores reales:
#   cp .env.example .env
# El fichero .env NO se sube al repositorio (esta en .gitignore); este .example si.

# Usuario y contraseña del almacen de tripletas Fuseki
FUSEKI_USER=admin
FUSEKI_PASSWORD=cambia_esta_contraseña

# Clave secreta para firmar los tokens JWT (usa una cadena larga y aleatoria)
JWT_SECRET=pon_aqui_una_clave_larga_y_aleatoria
